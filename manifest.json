{
  "manifest_version": 3,
  "name": "WhatsApp Quick Link Native",
  "version": "0.4.0",
  "description": "Turns phone numbers on any webpage into clickable WhatsApp (wa.me) links, inline where they appear.",
  "permissions": ["storage"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["country-data.js", "phone-parser.js", "content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "WhatsApp Quick Link"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
